[Unit]
Description=IncidentIQ FastAPI backend (uvicorn)
Documentation=https://github.com/praneethhh18/IncidentIQ
After=network-online.target
Wants=network-online.target
# StartLimitIntervalSec lives in [Unit] in current systemd; the old
# place in [Service] still works but emits a deprecation warning on
# every reload. Caps retries at 5 in 60s so a broken deploy doesn't
# hot-loop forever.
StartLimitIntervalSec=60s
StartLimitBurst=5

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/incidentiq/backend

# Persistent state directory. systemd creates /var/lib/incidentiq with
# the right ownership before ExecStart runs - this is where the SQLite
# store lives, so incidents survive restarts and deploys.
StateDirectory=incidentiq
StateDirectoryMode=0750

# All secrets (AWS keys, Datadog keys, GitHub OAuth secret, etc.) live
# in this file. The deploy bootstrap copies an example version; the
# operator fills in real values before the first systemctl start.
EnvironmentFile=/opt/incidentiq/backend/.env

# Bind to loopback only - nginx fronts us on :443. Two workers because
# Bedrock calls are I/O-bound and we want one to keep serving while
# another is mid-Converse-API call.
ExecStart=/opt/incidentiq/backend/.venv/bin/uvicorn \
    app.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --workers 2 \
    --proxy-headers \
    --forwarded-allow-ips=127.0.0.1 \
    --log-level info \
    --access-log

# Restart on crash. The burst limit lives in [Unit] above.
Restart=on-failure
RestartSec=3s

# Reasonable hardening - the process doesn't need to write outside its
# workdir or read user home dirs.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ProtectKernelTunables=true
ProtectControlGroups=true

# Don't kill in-flight requests instantly on stop / restart.
KillSignal=SIGINT
TimeoutStopSec=20s

[Install]
WantedBy=multi-user.target
