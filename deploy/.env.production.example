# IncidentIQ - production .env on the EC2 box at /opt/incidentiq/backend/.env
#
# Fill in the real values from your local backend/.env (the AWS keys
# from your Bedrock-only account, the Datadog keys, the GitHub OAuth
# secret). Do NOT commit this file with real values - it's gitignored.

# ── AWS Bedrock (from Account A, your existing Bedrock account) ──────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# ── Datadog (US5 site for praneethhh0218 account) ────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=us5.datadoghq.com

# ── GitHub OAuth ─────────────────────────────────────────────────────
# IMPORTANT: the callback URL must match what's configured at
# https://github.com/settings/developers -> IncidentIQ OAuth App.
# For production it must be the HTTPS api.nexusagent.in URL below.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=https://api.nexusagent.in/api/v1/auth/github/callback
GITHUB_OAUTH_POST_LOGIN_REDIRECT=https://incidentiq.nexusagent.in/dashboard

# ── Optional: Slack webhook + SendGrid email + Grafana + New Relic ───
# Leave blank to disable - the app degrades gracefully.
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=incidentiq@nexusagent.in
NOTIFY_EMAIL=
GRAFANA_URL=
GRAFANA_API_KEY=
NEW_RELIC_USER_KEY=
NEW_RELIC_ACCOUNT_ID=

# ── Server ───────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
# CORS - the frontend on Vercel must be allowed to call this API.
CORS_ORIGINS=https://incidentiq.nexusagent.in,https://nexusagent.in
